{
  "workspace": [
    "lib/cli-args-env",
    "lib/http-error",
    "lib/hono-error-middleware",
    "lib/logger",
    "lib/event-bus",
    "lib/hono-factory-static-files-fs",
    "hono-http-static"
  ],
  "nodeModulesDir": "auto",
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@hono/hono": "jsr:@hono/hono@^4"
  },
  "tasks": {
    "test": "deno test --allow-env --allow-read --allow-write --allow-run test/",
    "test:pure": "deno test test/pure_test.ts",
    "test:hono": "deno test --allow-env --allow-read --allow-write test/hono_test.ts",
    "test:cli": "deno test --allow-run --allow-read test/cli_smoke_test.ts"
  }
}
